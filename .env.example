NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
OFFLINE_SYNC_SECRET=your_32_byte_hex_secret_here
HMAC_SECRET=your_32_byte_hex_secret_here
RESEND_API_KEY=your_resend_api_key_here
EMAIL_FROM=noreply@yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── DEV-ONLY AUTO-LOGIN (never enable in production) ────────────────────
# Set DEV_AUTO_LOGIN=true in .env.local to auto-sign-in as the test admin
# or test student when hitting /admin/* or /student/* without a session.
# The route handler at /api/dev-auto-login + middleware hard-gate this on
# NODE_ENV !== 'production' — do NOT set these vars on Vercel.
DEV_AUTO_LOGIN=false
DEV_TEST_ADMIN_EMAIL=admin@mindspark.test
DEV_TEST_ADMIN_PASSWORD=
DEV_TEST_STUDENT_EMAIL=student-001@mindspark.local
DEV_TEST_STUDENT_PASSWORD=


